# Copy this to .env for local (non-Docker) development.
# When running via docker-compose, these are set directly in docker-compose.yml.

DATABASE_URL=postgresql://surveillance:surveillance@localhost:5432/surveillance
VIDEO_STORAGE_PATH=./data/videos
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.4
REID_SIMILARITY_THRESHOLD=0.7
FRAME_SAMPLE_RATE=5
